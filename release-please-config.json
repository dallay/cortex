{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "rust",
  "include-component-in-tag": false,
  "changelog-sections": [
    { "type": "feat", "section": "Features" },
    { "type": "fix", "section": "Bug Fixes" },
    { "type": "perf", "section": "Performance" },
    { "type": "revert", "section": "Reverts" },
    { "type": "docs", "section": "Documentation" },
    { "type": "style", "section": "Styles" },
    { "type": "refactor", "section": "Code Refactoring" },
    { "type": "build", "section": "Build System" },
    { "type": "ci", "section": "Continuous Integration" },
    { "type": "test", "section": "Tests" },
    { "type": "chore", "section": "Chores" }
  ],
  "packages": {
    "apps/rook": {
      "component": "rook",
      "extra-files": [
        { "type": "json", "path": "apps/rook/Cargo.toml", "jsonpath": "$.package.version" },
        {
          "type": "json",
          "path": "apps/rook/npm/rook/package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "apps/rook/npm/rook/package.json",
          "jsonpath": "$.optionalDependencies['@dallay/rook-darwin-x64']"
        },
        {
          "type": "json",
          "path": "apps/rook/npm/rook/package.json",
          "jsonpath": "$.optionalDependencies['@dallay/rook-darwin-arm64']"
        },
        {
          "type": "json",
          "path": "apps/rook/npm/rook/package.json",
          "jsonpath": "$.optionalDependencies['@dallay/rook-linux-x64']"
        },
        {
          "type": "json",
          "path": "apps/rook/npm/rook/package.json",
          "jsonpath": "$.optionalDependencies['@dallay/rook-linux-arm64']"
        },
        {
          "type": "json",
          "path": "apps/rook/npm/rook/package.json",
          "jsonpath": "$.optionalDependencies['@dallay/rook-windows-x64']"
        },
        {
          "type": "json",
          "path": "apps/rook/npm/rook/package.json",
          "jsonpath": "$.optionalDependencies['@dallay/rook-windows-arm64']"
        }
      ]
    }
  },
  "draft": false,
  "prerelease": false,
  "plugins": [
    {
      "type": "cargo-workspace",
      "merge": false
    }
  ]
}