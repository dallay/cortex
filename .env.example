# Provider CRUD encryption (required when provider_crud.enabled = true)
# Generate a strong passphrase: openssl rand -base64 32
ENCRYPTION_PASSPHRASE=your-encryption-passphrase-here
# Generate a random salt: openssl rand -hex 16
ENCRYPTION_SALT=your-16-char-hex-salt-here

# Optional: Path to config file (defaults to ~/.config/cortex/rook.toml)
# ROOK_CONFIG=/path/to/rook.toml
