# =============================================================================
# Dockerfile.runtime — Minimal runtime image with pre-built rook binary
# Usage:
#   docker build -f dev/Dockerfile.runtime -t rook:e2e-ubuntu .
# =============================================================================

FROM ubuntu:24.04

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    libssl3 \
    libsqlite3-0 \
    curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy pre-built binary (passed in via --build-arg or copy)
COPY --from=builder /app/target/debug/rook /usr/local/bin/rook
COPY dev/test-configs/rook-minimal.toml /app/rook.toml

EXPOSE 8080

ENTRYPOINT ["/usr/local/bin/rook"]
CMD ["--config", "/app/rook.toml"]
